<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="202606122354" author="higor">
        <createTable tableName="empresa">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="true"/>
            </column>
            
            <column name="razaoSocial" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            
            <column name="cnpj" type="varchar(14)">
                <constraints unique="true" nullable="false"/>
            </column>

            <column name="logradouro" type="varchar(64)"/>
            <column name="municipio" type="varchar(64)"/>
            <column name="numero" type="varchar(10)"/>
            <column name="complemento" type="varchar(64)"/>
            <column name="bairro" type="varchar(64)"/>
            <column name="cep" type="varchar(8)"/>
            <column name="telefone" type="varchar(32)"/>
            <column name="email" type="varchar">
                <constraints nullable="false"/>
            </column>
            <column name="site" type="varchar(1000)"/>
            <column name="usuario" type="varchar(20)">
                <constraints unique="true" nullable="false"/>
            </column>

            <column name="password" type="varchar"/>
            <column name="createdAt" type="timestamp">
                <constraints nullable="false"/>
            </column>

            <column name="updatedAt" type="timestamp">
                <constraints nullable="false"/>
            </column>


        </createTable>
    </changeSet>
</databaseChangeLog>