<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="130620261322" author="higor">
        <dropForeignKeyConstraint baseTableName="comprador" constraintName="empresa_comp_fk"/>
        <addForeignKeyConstraint baseTableName="comprador"
                                 baseColumnNames="empresa_id"
                                 constraintName="empresa_comp_fk"
                                 referencedTableName="empresa"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="130620261323" author="higor">
        <dropForeignKeyConstraint baseTableName="comprador" constraintName="leilao_comp_fk"/>
        <addForeignKeyConstraint baseTableName="comprador"
                                 baseColumnNames="leilao_id"
                                 constraintName="leilao_comp_fk"
                                 referencedTableName="leilao"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="160620261601" author="higor">
        <dropForeignKeyConstraint baseTableName="lote" constraintName="lote_leilao_fk"/>
        <addForeignKeyConstraint baseTableName="lote"
                                 baseColumnNames="leilao_id"
                                 constraintName="lote_leilao_fk"
                                 referencedTableName="leilao"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="160620261602" author="higor">
        <dropForeignKeyConstraint baseTableName="leilao" constraintName="leilao_vendedor_fk"/>
        <addForeignKeyConstraint baseTableName="leilao"
                                 baseColumnNames="vendedor"
                                 constraintName="leilao_vendedor_fk"
                                 referencedTableName="empresa"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"/>
    </changeSet>
</databaseChangeLog>
